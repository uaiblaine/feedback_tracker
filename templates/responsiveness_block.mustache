{{!
    This file is part of Moodle - http://moodle.org/

    @template    block_feedback_tracker/responsiveness_block

    Wraps the per-group responsiveness cards rendered inside the block.
    Shows the empty-state message when no rollup rows exist for the course.

    Context variables required:
    * empty       Truthy when no cards are present
    * emptytext   Empty-state message
    * cards       Array of contexts for responsiveness_card.mustache

    Example context (json):
    {
        "empty": true,
        "emptytext": "No data yet for this course.",
        "cards": []
    }
}}
{{#empty}}
    <div class="bft-empty">{{emptytext}}</div>
{{/empty}}
{{^empty}}
    <div class="bft-card-list">
        {{#cards}}
            {{> block_feedback_tracker/responsiveness_card }}
        {{/cards}}
    </div>
{{/empty}}
