    @template    block_feedback_tracker/responsiveness_card

    One responsiveness card per (course, group) — the no-JS fallback. Collapsible
    via native <details>: a gray header (title + optional subtitle + band badge)
    toggles the body — score gauge, the three pending-band counts, metrics row,
    optional paused-today strip, optional 14-day sparkline, and a drilldown link.

    Context variables required:
    * title          Group or course title (string)
    * hassubtitle    Truthy if a subtitle line should render
    * subtitle       Smaller line under the title (string)
    * band           SLA band slug (excellent|good|regular|critical|pending; string, may be empty)
    * bandlabel      Localised band label (string, empty if no band)
    * gauge          Sub-context for score_gauge.mustache
    * counts         Array of {label, value} for the band counts row
    * metrics        Array of {label, value} for the metrics row
    * haspause       Truthy if the pause strip should render
    * pausestrip     Already-formatted pause-strip text (string)
    * hassparkline   Truthy if the 14-day sparkline should render
    * sparkline      Sub-context for sparkline.mustache
    * courseid       Course id
    * drilldownurl   URL string
    * drilldowntext  Localised link text

    Example context (json):
    {
        "title": "Class A",
        "hassubtitle": true,
        "subtitle": "300423743 | LURDES PENNA",
        "band": "excellent",
        "bandlabel": "Excellent",
        "gauge": {
            "size": 100, "cx": 50, "r": 44, "arc": 247.4, "circumference": 276.5,
            "colour": "#047857", "label": "95", "texty": 57, "fontsize": 28
        },
        "counts": [
            {"label": "Waiting", "value": "2"},
            {"label": "Attention", "value": "1"},
            {"label": "Priority", "value": "0"}
        ],
        "metrics": [
            {"label": "Median", "value": "12.0 h"},
            {"label": "Within SLA", "value": "80%"},
            {"label": "Trend 7d", "value": "▲ 18%"}
        ],
        "haspause": false, "pausestrip": "",
        "hassparkline": false, "sparkline": {},
        "courseid": 2,
        "drilldownurl": "/blocks/feedback_tracker/pages/group_drilldown.php?courseid=2&groupid=0",
        "drilldowntext": "Open pending list"
    }
}}
<details class="bft-card" open>
    <summary class="bft-card-head">
        <span class="bft-card-head-titles">
            <span class="bft-card-title">{{title}}</span>
            {{#hassubtitle}}<span class="bft-card-subtitle">{{subtitle}}</span>{{/hassubtitle}}
        </span>
        {{#bandlabel}}<span class="bft-badge bft-badge-{{band}}">{{bandlabel}}</span>{{/bandlabel}}
    </summary>
    <div class="bft-card-body">
        <div class="bft-card-gauge">
            {{#gauge}}{{> block_feedback_tracker/score_gauge }}{{/gauge}}
        </div>
        <div class="bft-card-data">
            <div class="bft-counts">
                {{#counts}}
                    <div class="bft-count">
                        <span class="bft-count-value">{{value}}</span>
                        <span class="bft-count-label">{{label}}</span>
                    </div>
                {{/counts}}
            </div>
            <div class="bft-metrics">
                {{#metrics}}
                    <div class="bft-metric">
                        <span class="bft-metric-label">{{label}}</span>
                        <span class="bft-metric-value">{{value}}</span>
                    </div>
                {{/metrics}}
            </div>
            {{#hassparkline}}
                <div class="bft-card-sparkline">
                    {{#sparkline}}{{> block_feedback_tracker/sparkline }}{{/sparkline}}
                </div>
            {{/hassparkline}}
            {{#haspause}}
                <div class="bft-pause-strip">{{pausestrip}}</div>
            {{/haspause}}
            <div class="bft-card-foot">
                <a class="bft-drilldown" href="{{drilldownurl}}">{{drilldowntext}}</a>
            </div>
        </div>
    </div>
</details>
