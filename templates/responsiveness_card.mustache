    @template    block_feedback_tracker/responsiveness_card

    One responsiveness card per (course, group). Contains the score gauge,
    counts row, metrics row, optional paused-today strip, optional score
    breakdown <details>, and a drilldown link.

    Context variables required:
    * title          Group or course title (string)
    * band           SLA band slug (excellent|good|regular|critical|pending; string, may be empty)
    * bandlabel      Localised band label (string, empty if no band)
    * gauge          Sub-context for score_gauge.mustache
    * counts         Array of {label, value} for the counts row
    * metrics        Array of {label, value} for the metrics row
    * haspause       Truthy if the pause strip should render
    * pausestrip     Already-formatted pause-strip text (string)
    * hasbreakdown   Truthy if the score-breakdown <details> should render
    * breakdown      Sub-context for the breakdown table:
                        {summary, strterm, strvalue, strweight, strpts, strtotal,
                         rows: [{label, valuestr, weightstr, ptsstr}], totalstr}
    * hassparkline   Truthy if the 30-day sparkline should render
    * sparkline      Sub-context for sparkline.mustache
    * courseid       Course id (data-courseid on the refresh button)
    * refreshtext    Localised refresh button label
    * drilldownurl   URL string
    * drilldowntext  Localised link text

    Example context (json):
    {
        "title": "Class A",
        "band": "excellent",
        "bandlabel": "Excellent",
        "gauge": {
            "size": 100, "cx": 50, "r": 44, "arc": 247.4, "circumference": 276.5,
            "colour": "#10b981", "label": "95", "texty": 57, "fontsize": 28
        },
        "counts": [
            {"label": "Pending", "value": "3"},
            {"label": "Priority", "value": "0"},
            {"label": "Over goal", "value": "1"}
        ],
        "metrics": [
            {"label": "Median", "value": "12.0 h"},
            {"label": "Within SLA", "value": "80%"},
            {"label": "Trend 30d", "value": "▼ 18%"}
        ],
        "haspause": false, "pausestrip": "",
        "hasbreakdown": false, "breakdown": {},
        "hassparkline": false, "sparkline": {},
        "courseid": 2,
        "refreshtext": "Refresh now",
        "drilldownurl": "/blocks/feedback_tracker/pages/group_drilldown.php?courseid=2&groupid=0",
        "drilldowntext": "Open pending list"
    }
}}
<div class="bft-card">
    <div class="bft-card-head">
        <strong class="bft-card-title">{{title}}</strong>
        {{#bandlabel}}<span class="bft-badge bft-badge-{{band}}">{{bandlabel}}</span>{{/bandlabel}}
        <button type="button" class="bft-refresh"
                data-courseid="{{courseid}}"
                title="{{refreshtext}}"
                aria-label="{{refreshtext}}">⟳</button>
    </div>
    <div class="bft-card-body">
        <div class="bft-card-gauge">
            {{#gauge}}{{> block_feedback_tracker/score_gauge }}{{/gauge}}
        </div>
        <div class="bft-card-data">
            <div class="bft-counts">
                {{#counts}}
                    <div class="bft-count">
                        <span class="bft-count-value">{{value}}</span>
                        <span class="bft-count-label">{{label}}</span>
                    </div>
                {{/counts}}
            </div>
            <div class="bft-metrics">
                {{#metrics}}
                    <div class="bft-metric">
                        <span class="bft-metric-label">{{label}}</span>
                        <span class="bft-metric-value">{{value}}</span>
                    </div>
                {{/metrics}}
            </div>
            {{#hassparkline}}
                <div class="bft-card-sparkline">
                    {{#sparkline}}{{> block_feedback_tracker/sparkline }}{{/sparkline}}
                </div>
            {{/hassparkline}}
            {{#haspause}}
                <div class="bft-pause-strip">{{pausestrip}}</div>
            {{/haspause}}
            {{#hasbreakdown}}
                {{#breakdown}}
                    <details class="bft-breakdown">
                        <summary>{{summary}}</summary>
                        <table class="bft-breakdown-table">
                            <thead>
                                <tr>
                                    <th>{{strterm}}</th>
                                    <th class="bft-breakdown-num">{{strvalue}}</th>
                                    <th class="bft-breakdown-num">{{strweight}}</th>
                                    <th class="bft-breakdown-num">{{strpts}}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#rows}}
                                    <tr>
                                        <td>{{label}}</td>
                                        <td class="bft-breakdown-num">{{valuestr}}</td>
                                        <td class="bft-breakdown-num">{{weightstr}}</td>
                                        <td class="bft-breakdown-num">{{ptsstr}}</td>
                                    </tr>
                                {{/rows}}
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="3">{{strtotal}}</th>
                                    <th class="bft-breakdown-num">{{totalstr}}</th>
                                </tr>
                            </tfoot>
                        </table>
                    </details>
                {{/breakdown}}
            {{/hasbreakdown}}
            <div class="bft-card-foot">
                <a class="bft-drilldown" href="{{drilldownurl}}">{{drilldowntext}}</a>
            </div>
        </div>
    </div>
</div>
