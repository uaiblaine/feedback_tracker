{{!
    This file is part of Moodle - http://moodle.org/

    @template    block_feedback_tracker/score_gauge

    SVG ring gauge for the Academic Responsiveness Score (0-100).

    Context variables required:
    * size           Square pixel size of the SVG (number)
    * cx             Centre coordinate = size / 2 (number)
    * r              Ring radius (number)
    * arc            Length of the filled arc in user units (number)
    * circumference  Total ring circumference (number)
    * colour         Stroke colour for the filled arc (string, hex)
    * label          Score label to render inside the ring (string)
    * texty          Y-coordinate of the score label (number)
    * fontsize       Font size for the score label in user units (number)

    Example context (json):
    {
        "size": 100,
        "cx": 50,
        "r": 44,
        "arc": 247.4,
        "circumference": 276.5,
        "colour": "#047857",
        "label": "95",
        "texty": 57,
        "fontsize": 28
    }
}}
<svg class="bft-gauge" viewBox="0 0 {{size}} {{size}}" width="{{size}}" height="{{size}}"
     role="img" aria-label="Responsiveness score {{label}}">
    <circle cx="{{cx}}" cy="{{cx}}" r="{{r}}" fill="none" stroke="#e5e7eb" stroke-width="8"/>
    <circle cx="{{cx}}" cy="{{cx}}" r="{{r}}" fill="none" stroke="{{colour}}" stroke-width="8"
            stroke-linecap="round"
            stroke-dasharray="{{arc}} {{circumference}}"
            transform="rotate(-90 {{cx}} {{cx}})"/>
    <text x="{{cx}}" y="{{texty}}" text-anchor="middle" font-size="{{fontsize}}"
          font-weight="700" fill="#0f172a">{{label}}</text>
</svg>
